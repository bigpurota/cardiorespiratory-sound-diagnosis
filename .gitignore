# Python environment
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Raw audio — never commit (~2.4 GB; ICBHI is not licensed for redistribution).
# The small processed metadata (manifest + ICBHI cycle annotations) under
# data/processed/ IS kept for reviewer transparency; heavy feature caches stay
# out via the *.npy/*.npz rules below.
data/raw/

# Large generated feature caches
*.npy
*.npz

# Model checkpoints (large)
*.pth
*.pt
*.pkl

# IDE & tooling artifacts
.DS_Store
.vscode/
.idea/
.claude/

# MS Office lock files (created when a .docx is open in Word)
~$*

# Local project notes and scratch planning — not part of the academic deliverable.
CLAUDE.md
AGENTS.md
.planning/

# Jupyter notebook checkpoints
.ipynb_checkpoints/

# Temporary files
*.tmp
*.log

# Secrets & local handoffs — NEVER commit (SSH keys, API keys, GPU-box session notes)
.continue-here.md
*.key
id_ed25519
id_ed25519.pub
*.vast_api_key
.env
*.pem

# Local reference materials (official course annexes, templates, admin docs) —
# kept locally only, not part of the committed deliverable
reference/

# DO NOT gitignore the following: uv.lock, requirements.txt, .python-version, params/, results/tables/, results/figures/
# uv.lock               — exact dependency lockfile (commit this)
# requirements.txt      — pip-compatible export for Colab/graders (commit this)
# .python-version       — Python version pin read by uv (commit this)
# params/               — modality-specific preprocessing parameters
# results/tables/       — experiment result CSVs for the report
# results/figures/      — report figures

# Typst build artifact (regenerate with: typst compile report/main.typ report/main.pdf)
report/main.pdf
# Temporary per-page PNG renders used for visual proofing
report/_check_*.png
