# Python environment
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Raw and processed data — never commit (~1.7 GB)
data/

# Large generated feature caches
*.npy
*.npz

# Model checkpoints (large)
*.pth
*.pt
*.pkl

# IDE & tooling artifacts
.DS_Store
.vscode/
.idea/
.claude/

# Jupyter notebook checkpoints
.ipynb_checkpoints/

# Temporary files
*.tmp
*.log

# Secrets & local handoffs — NEVER commit (SSH keys, API keys, GPU-box session notes)
.continue-here.md
*.key
id_ed25519
id_ed25519.pub
*.vast_api_key
.env
*.pem

# Local reference materials (official course annexes + title-page templates —
# bulky / course-copyright; kept locally under reference/, documented in reference/README.md)
reference/*.pdf
reference/*.docx
reference/*.zip

# DO NOT gitignore the following: uv.lock, requirements.txt, .python-version, params/, results/tables/, results/figures/
# uv.lock               — exact dependency lockfile (commit this)
# requirements.txt      — pip-compatible export for Colab/graders (commit this)
# .python-version       — Python version pin read by uv (commit this)
# params/               — modality-specific preprocessing parameters
# results/tables/       — experiment result CSVs for the report
# results/figures/      — report figures

# Typst build artifact (regenerate with: typst compile report/main.typ report/main.pdf)
report/main.pdf
